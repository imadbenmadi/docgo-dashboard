# healthpathglobal Dashboard (Vite) environment

# Backend base URL (scheme + domain + optional path, no trailing slash)
# Examples:
#   VITE_API_URL=https://backend.healthpathglobal.com
VITE_API_URL=https://backend.healthpathglobal.com

# Optional upload moderation UI
VITE_CHECK_UPLOADS=false

# Builder.io
VITE_PUBLIC_BUILDER_KEY=
